[
  ESTETIK - Görsel Minimalizm ve Saf Mantık
  Bu kod, ekran çıktısı olarak "ESTETIK" kelimesini üretir.
]

++++++++++[>+++++++>++++++++>+++++++++<<< -]
> -.                    Print 'E' (70-1=69)
> +++.                  Print 'S' (80+3=83)
+.                      Print 'T' (83+1=84)
<< -.                   Print 'E' (70-1=69)
>> +.                   Print 'T' (83+1=84)
<< ++++.                Print 'I' (69+4=73)
++.                     Print 'K' (73+2=75)
